{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "remote-forms": {
      "projectType": "application",
      "root": "",
      "sourceRoot": "src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular-architects/native-federation:build",
          "options": { "target": "remote-forms:build-original:production" },
          "configurations": {
            "production": { "target": "remote-forms:build-original:production" },
            "development": { "target": "remote-forms:build-original:development" }
          },
          "defaultConfiguration": "production"
        },
        "build-original": {
          "builder": "@angular/build:application",
          "options": {
            "outputPath": "dist/remote-forms",
            "index": "src/index.html",
            "browser": "src/main.ts",
            "tsConfig": "tsconfig.app.json",
            "styles": ["src/styles.css"],
            "scripts": []
          },
          "configurations": {
            "production": {
              "baseHref": "/mfe-playground/remote-forms/",
              "budgets": [
                { "type": "initial", "maximumWarning": "500kB", "maximumError": "1MB" },
                { "type": "anyComponentStyle", "maximumWarning": "4kB", "maximumError": "8kB" }
              ],
              "outputHashing": "all"
            },
            "development": { "optimization": false, "extractLicenses": false, "sourceMap": true }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular-architects/native-federation:build",
          "options": { "target": "remote-forms:serve-original:development", "rebuildDelay": 0, "dev": true, "port": 4202 }
        },
        "serve-original": {
          "builder": "@angular/build:dev-server",
          "options": { "port": 4202 },
          "configurations": {
            "production": { "buildTarget": "remote-forms:build-original:production" },
            "development": { "buildTarget": "remote-forms:build-original:development" }
          },
          "defaultConfiguration": "development"
        }
      }
    }
  }
}
