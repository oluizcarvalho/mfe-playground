{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "host": {
      "projectType": "application",
      "root": "",
      "sourceRoot": "src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular-architects/native-federation:build",
          "options": {
            "target": "host:build-original:production"
          },
          "configurations": {
            "production": { "target": "host:build-original:production" },
            "development": { "target": "host:build-original:development" }
          },
          "defaultConfiguration": "production"
        },
        "build-original": {
          "builder": "@angular/build:application",
          "options": {
            "outputPath": "dist/host",
            "index": "src/index.html",
            "browser": "src/main.ts",
            "tsConfig": "tsconfig.app.json",
            "assets": [
              {
                "glob": "federation.manifest.json",
                "input": "src/",
                "output": "/"
              }
            ],
            "styles": ["src/styles.css"],
            "scripts": []
          },
          "configurations": {
            "production": {
              "baseHref": "/mfe-playground/",
              "budgets": [
                { "type": "initial", "maximumWarning": "500kB", "maximumError": "1MB" },
                { "type": "anyComponentStyle", "maximumWarning": "4kB", "maximumError": "8kB" }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular-architects/native-federation:build",
          "options": {
            "target": "host:serve-original:development",
            "rebuildDelay": 0,
            "dev": true,
            "port": 4200
          }
        },
        "serve-original": {
          "builder": "@angular/build:dev-server",
          "configurations": {
            "production": { "buildTarget": "host:build-original:production" },
            "development": { "buildTarget": "host:build-original:development" }
          },
          "defaultConfiguration": "development"
        }
      }
    }
  }
}
